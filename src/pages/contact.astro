---
import Base from '../layouts/Base.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'contact');
const { Content } = entry ? await render(entry) : { Content: null };
---
<Base title="Contact — Stone Branches">
  <div class="page">
    <p class="eyebrow">Contact</p>
    <h1 class="display">Get in touch</h1>
    <div class="prose">
      {Content && <Content />}
      <p>Email <a href="mailto:james@stonebranches.life">james@stonebranches.life</a>.</p>
    </div>
  </div>
</Base>
